MIMO_API_KEY=sk-xxxx                    # 从 https://platform.xiaomimimo.com 获取
MIMO_BASE_URL=https://api.xiaomimimo.com/v1  # 可选，默认值如右
LLM_MODEL=mimo-v2-pro                   # 主模型（sections / chat expert / dayun-step / gua）
LLM_FAST_MODEL=mimo-v2-flash            # 快模型（router intent 分类 / liunian）
LLM_FALLBACK_MODEL=mimo-v2-flash        # 主模型失败时降级
PORT=3101
